# Copy this file to  supabase/.env  and fill in your values, then run:
#   node supabase/seed.mjs
#
# Both come from Supabase → Settings → API.
# Use the SECRET service_role key (NOT the anon/public key) — the seed needs admin rights.

SUPABASE_URL=https://YOUR-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
